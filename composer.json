{
  "name": "kas-cor/console-progress-bar",
  "type": "library",
  "description": "Console progress bar",
  "keywords": ["console", "progress", "bar"],
  "homepage": "https://github.com/kas-cor/console-progress-bar",
  "license": "MIT",
  "authors": [
    {
      "name": "kas-cor",
      "email": "kascorp@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "ext-mbstring": "*"
  },
  "suggest": {
    "psr/log": "Allows using PSR-3 logger as output handler (LoggerOutput)"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.65",
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse --configuration phpstan.neon.dist",
    "cs-fix": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix",
    "cs-check": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --dry-run --diff",
    "check": ["@phpstan", "@test"]
  },
  "autoload": {
    "psr-4": {
      "KasCor\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "KasCor\\Tests\\": "tests"
    }
  }
}